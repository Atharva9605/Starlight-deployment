# ============================================================
#  Starlight AI-CRM Mailer — .env.example
#  Copy this to .env and fill in your real values.
# ============================================================

# ── Sender details ───────────────────────────────────────────
SENDER_NAME=Vivek Dhondarkar
SENDER_COMPANY=Starlight LED Lighting
SENDER_PHONE=+91-9619436086
SENDER_WEBSITE=https://www.starlightlinearled.com
SENDER_EMAIL=info@starlightlinearled.com
COMPANY_LOGO_URL=https://i.ibb.co/b5NVtcS3/starlight.jpg

# ── Azure OpenAI ─────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# ── Blob Storage (choose one backend) ────────────────────────
# Options: local | cloudinary | azure   (default: local)

# LOCAL — saves to static/page_images/, serve with:
#   python -m http.server 8000 --directory static
BLOB_BACKEND=local
STATIC_SERVER_URL=http://localhost:8000

# CLOUDINARY — free 25 GB/month, real public URLs for sent emails
# BLOB_BACKEND=cloudinary
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# AZURE — Azure Blob Storage account
# BLOB_BACKEND=azure
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=xxx;AccountKey=xxx;EndpointSuffix=core.windows.net
# AZURE_STORAGE_CONTAINER=starlight-catalogues

# ── Google G Suite email sending ─────────────────────────────
GSUITE_SERVICE_ACCOUNT_JSON=service_account.json
GSUITE_DELEGATED_USER=vivek@starlightlinearled.com
